{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": ["ES2022"],
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noEmit": true,
    "rootDir": "..",
    "jsx": "react",
    "types": ["node"]
  },
  "include": ["./**/*"],
  "exclude": ["node_modules"]
}
